# ⚠️  CE FICHIER CONTIENT DES PLACEHOLDERS — NE JAMAIS Y METTRE TES VRAIES CLÉS
# ⚠️  CE FICHIER EST VERSIONNÉ UNIQUEMENT COMME TEMPLATE DE STRUCTURE
#
# COMMENT CRÉER LE VRAI SECRET (sans commiter tes clés) :
#
# Option A — kubectl create secret (recommandée) :
#   kubectl create secret generic kamerstay-secrets \
#     --namespace kamerstay \
#     --from-literal=MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/kamerstay" \
#     --from-literal=JWT_SECRET="ton_jwt_secret_tres_long" \
#     --from-literal=ANTHROPIC_API_KEY="sk-ant-..." \
#     --from-literal=RESEND_API_KEY="re_..." \
#     --from-literal=RESEND_FROM_EMAIL="noreply@tondomaine.com"
#
# Option B — éditer ce fichier LOCALEMENT (sans le commiter) :
#   1. Copie ce fichier : cp secret.yaml secret.local.yaml
#   2. Encode tes valeurs en base64 : echo -n "ma_valeur" | base64
#   3. Remplace les placeholders dans secret.local.yaml
#   4. kubectl apply -f secret.local.yaml
#   5. NE JAMAIS faire git add secret.local.yaml
#      (ajoute "k8s/secret.local.yaml" dans .gitignore)
#
# Pour vérifier que le secret est en place :
#   kubectl get secret kamerstay-secrets -n kamerstay
#   kubectl describe secret kamerstay-secrets -n kamerstay

apiVersion: v1
kind: Secret
metadata:
  name: kamerstay-secrets
  namespace: kamerstay
type: Opaque
data:
  # Valeurs encodées en base64 — remplace chaque "REMPLACER" par : echo -n "ta_valeur" | base64
  MONGODB_URI: UkVNUExBQ0VS        # REMPLACER
  JWT_SECRET: UkVNUExBQ0VS         # REMPLACER
  ANTHROPIC_API_KEY: UkVNUExBQ0VS  # REMPLACER
  RESEND_API_KEY: UkVNUExBQ0VS     # REMPLACER
  RESEND_FROM_EMAIL: UkVNUExBQ0VS  # REMPLACER
