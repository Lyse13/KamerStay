  "info": {
    "_postman_id": "f11b0f1d-7547-418b-9eef-af95bb3fee53",
    "name": "KamerStay API",
    "description": "Collection Postman de l'API KamerStay — plateforme de réservation hôtelière géolocalisée pour le Cameroun.\n\n**Utilisation**\n1. Sélectionner l'environnement (variable `baseUrl`).\n2. Exécuter `Authentification > Se connecter` : le jeton JWT est automatiquement enregistré dans la variable `token`.\n3. Toutes les autres requêtes utilisent ce jeton via l'authentification Bearer héritée au niveau de la collection.\n\nAuteur : Mouandeu Pangop Lysette Merveille (ICTU20223121)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
