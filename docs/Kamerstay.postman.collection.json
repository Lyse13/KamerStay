      "name": "Authentification",
      "item": [
        {
          "name": "Créer un compte",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Le mot de passe est haché avec BCrypt avant enregistrement.",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Lysette Mouandeu\",\n  \"email\": \"lysette@example.com\",\n  \"password\": \"MotDePasse123\",\n  \"phoneNumber\": \"+237690000000\",\n  \"role\": \"TRAVELER\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Se connecter",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Retourne un jeton JWT valable 24 h. Route limitée à 5 tentatives par minute et par IP.",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"lysette@example.com\",\n  \"password\": \"MotDePasse123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Enregistre automatiquement le jeton dans la variable de collection",
                  "if (pm.response.code === 200) {",
                  "    const data = pm.response.json();",
                  "    if (data.token) {",
                  "        pm.collectionVariables.set('token', data.token);",
                  "        console.log('Jeton JWT enregistré');",
                  "    }",
                  "}",
                  "pm.test('Connexion réussie', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
